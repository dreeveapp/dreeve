{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% autoescape false %}
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">
                {{ "Activity management"|trans({}, 'admin') }}
            </h3>
        </div>
        {% if not overview.isEmpty() or not filters.isEmpty() %}
            <form method="get" class="mb-4 flex flex-wrap items-end gap-3">
                <div>
                    <label for="filter-sport-type" class="mt-0! text-xs text-gray-500">{{ "Sport type"|trans({}, 'admin') }}</label>
                    <select id="filter-sport-type" name="filters[sportType]">
                        <option value="">{{ "All"|trans }}</option>
                        {% for sportType in sportTypeOptions %}
                            <option value="{{ sportType.value }}" {{ sportType == filters.getSportType() ? 'selected' }}>{{ sportType|trans }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="filter-gear" class="mt-0! text-xs text-gray-500">{{ "Gear"|trans }}</label>
                    <select id="filter-gear" name="filters[gear]">
                        <option value="">{{ "All"|trans }}</option>
                        {% for gear in gearOptions %}
                            <option value="{{ gear.getId() }}" {{ gear.getId() == filters.getGearId() ? 'selected' }}>{{ gear.getName() }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="filter-device" class="mt-0! text-xs text-gray-500">{{ "Device"|trans }}</label>
                    <select id="filter-device" name="filters[device]">
                        <option value="">{{ "All"|trans }}</option>
                        {% for device in deviceOptions %}
                            <option value="{{ device.getName() }}" {{ device.getName() == filters.getDevice() ? 'selected' }}>{{ device.getName() }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="filter-import-source" class="mt-0! text-xs text-gray-500">{{ "Import source"|trans({}, 'admin') }}</label>
                    <select id="filter-import-source" name="filters[importSource]">
                        <option value="">{{ "All"|trans }}</option>
                        {% for importSource in importSourceOptions %}
                            <option value="{{ importSource.value }}" {{ importSource == filters.getImportSource() ? 'selected' }}>{{ importSource.label() }}</option>
                        {% endfor %}
                    </select>
                </div>
                <button type="submit" class="btn--primary">{{ "Apply"|trans({}, 'admin') }}</button>
                {% if not filters.isEmpty() %}
                    <a href="{{ relativeUrl(path('admin_manage_activity_overview')) }}" type="button" class="btn--secondary">
                        {{ "Clear filters"|trans({}, 'admin') }}
                    </a>
                {% endif %}
            </form>
        {% endif %}
        <div class="relative overflow-x-auto">
            <table class="data-table">
                <thead>
                <tr>
                    <th scope="col" class="text-left">
                        {{ "Name"|trans }}
                    </th>
                    <th scope="col" class="text-left">
                        {{ "Sport type"|trans({}, 'admin') }}
                    </th>
                    <th scope="col" class="text-left">
                        {{ "Date"|trans }}
                    </th>
                    <th scope="col" class="text-left">
                        {{ "Gear"|trans }}
                    </th>
                    <th scope="col" class="text-left">
                        {{ "Device"|trans }}
                    </th>
                    <th scope="col" class="narrow">
                        {{ "Commute"|trans({}, 'admin') }}
                    </th>
                    <th scope="col" class="narrow">
                        {{ "Images"|trans({}, 'admin') }}
                    </th>
                    <th scope="col" class="narrow">
                        <span class="sr-only">{{ "Edit"|trans({}, 'admin') }}</span>
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for activity in overview %}
                    <tr class="group/row">
                        <td class="whitespace-nowrap text-left">
                            <a class="block max-w-100 truncate font-medium text-blue-600 hover:underline"
                               title="{{ activity.getName() }}"
                               href="{{ relativeUrl('/activities#/activity/' ~ activity.getActivityId() ~ '.html') }}">
                                {{ activity.getName() }}
                            </a>
                        </td>
                        <td class="whitespace-nowrap text-left">
                            {{ activity.getSportType()|trans }}
                        </td>
                        <td class="whitespace-nowrap text-left">
                            {{ activity.getStartDate()|formatDate() }}
                        </td>
                        <td class="whitespace-nowrap text-left">
                            {% if activity.getGearName() %}
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
                                    {{ activity.getGearName() }}
                                </span>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td class="whitespace-nowrap text-left">
                            {% if activity.getDeviceName() %}
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
                                    {{ activity.getDeviceName() }}
                                </span>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td class="narrow whitespace-nowrap">
                            {{ (activity.isCommute() ? "Yes" : "No")|trans }}
                        </td>
                        <td class="narrow whitespace-nowrap">
                            {{ activity.getTotalImageCount() }}
                        </td>
                        <td class="narrow whitespace-nowrap">
                            <div class="inline-flex items-center gap-2">
                                <a href="{{ relativeUrl(path('admin_edit_activity', {activityId: activity.getActivityId()})) }}"
                                   class="inline-flex items-center justify-center text-gray-500 transition-colors hover:text-primary"
                                   title="{{ "Edit"|trans({}, 'admin') }}">
                                    <span class="sr-only">{{ "Edit"|trans({}, 'admin') }}</span>
                                    <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m14.304 4.844 2.852 2.852M7 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h11a1 1 0 0 0 1-1v-4.5m2.409-9.91a2.017 2.017 0 0 1 0 2.853l-6.844 6.844L8 14l.713-3.565 6.844-6.844a2.015 2.015 0 0 1 2.852 0Z"/>
                                    </svg>
                                </a>
                                {% if importMode.isFiles() %}
                                    <a href="{{ relativeUrl(path('admin_delete_activity', {activityId: activity.getActivityId()})) }}"
                                       class="inline-flex items-center justify-center text-gray-500 transition-colors hover:text-red-600"
                                       title="{{ "Delete"|trans({}, 'admin') }}">
                                        <span class="sr-only">{{ "Delete"|trans({}, 'admin') }}</span>
                                        <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 7h14m-9 3v8m4-8v8M10 3h4a1 1 0 0 1 1 1v3H9V4a1 1 0 0 1 1-1ZM6 7h12v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7Z"/>
                                        </svg>
                                    </a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                {% if overview.isEmpty() %}
                    <tr>
                        <td colspan="8">
                            <div class="flex flex-col items-center justify-center gap-3 py-12 px-4 text-center">
                                <span class="grid place-items-center size-12 rounded-full bg-gray-100 text-gray-400" aria-hidden="true">
                                    <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 9h6m-6 3h6m-6 3h6M6.996 9h.01m-.01 3h.01m-.01 3h.01M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z"/>
                                    </svg>
                                </span>
                                {% if filters.isEmpty() %}
                                    <div class="flex flex-col gap-1">
                                        <span class="text-sm font-medium text-gray-800">{{ "No activities imported yet."|trans({}, 'admin') }}</span>
                                        <span class="text-xs text-gray-500">{{ "Activities will appear here once they are imported."|trans({}, 'admin') }}</span>
                                    </div>
                                {% else %}
                                    <div class="flex flex-col gap-1">
                                        <span class="text-sm font-medium text-gray-800">{{ "No activities match the current filters."|trans({}, 'admin') }}</span>
                                    </div>
                                    <a href="{{ relativeUrl(path('admin_manage_activity_overview')) }}" class="btn--primary mt-1">
                                        {{ "Clear filters"|trans({}, 'admin') }}
                                    </a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
        {% include 'html/admin/component/pagination.html.twig' with {
            'total': overview.getTotal(),
            'pagination': overview.getPagination(),
        } only %}
    </div>
    {% endautoescape %}
{% endblock main %}
