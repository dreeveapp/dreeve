{% extends "html/admin/page/template.html.twig" %}

{% block main %}
    {% set cron = settings.cron ?? {} %}
    {% set cronActions = {
        'importDataAndBuildApp': {
            'label': "Import data & build app"|trans,
            'description': "Imports new Strava activities and rebuilds the app."|trans,
            'default': '0 2 * * *',
        },
        'gearMaintenanceNotification': {
            'label': "Gear maintenance notification"|trans,
            'description': "Sends a notification when gear maintenance is due. Requires a configured notification service."|trans,
            'default': '* * * * *',
        },
        'appUpdateAvailableNotification': {
            'label': "App update available notification"|trans,
            'description': "Sends a notification when a new app version is available. Requires a configured notification service."|trans,
            'default': '* * * * *',
        },
    } %}
    <div class="flex flex-col gap-4">
        <form data-dispatch-command="{{ dispatchCommand }}" class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
            <input type="hidden" name="group" value="{{ group.value }}">
            <div class="mb-5">
                <h3 class="text-lg font-semibold">{{ "Daemon"|trans }}</h3>
                <p class="description">
                    {{ "Scheduled actions the daemon runs at regular intervals. Only applies when the daemon container is set up."|trans }}
                </p>
            </div>
            <div data-form-error class="hidden mb-4 rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700" role="alert"></div>
            <div class="flex flex-col gap-3">
                {% for actionId, meta in cronActions %}
                    {% set stored = cron[actionId] ?? {} %}
                    <div class="flex flex-col gap-3 p-3 bg-gray-50 rounded-lg border border-gray-200">
                        <label class="flex items-center gap-2 mt-0! font-medium cursor-pointer">
                            <input type="checkbox" name="data[cron][{{ actionId }}][enabled]" value="1"
                                   {{ (stored.enabled ?? false) ? 'checked' : '' }}>
                            <span>{{ meta.label }}</span>
                        </label>
                        <p class="description mt-0!">{{ meta.description }}</p>
                        <div>
                            <label for="cron-{{ actionId }}">{{ "Cron expression"|trans }}</label>
                            <input type="text" id="cron-{{ actionId }}" name="data[cron][{{ actionId }}][expression]"
                                   value="{{ stored.expression ?? meta.default }}" required
                                   placeholder="{{ meta.default }}">
                            <p class="description">
                                {{ "Cron expression specifying when the action should run, e.g. '0 14 * * *' runs every day at 14:00. See crontab.guru for help."|trans }}
                            </p>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <div class="flex justify-end gap-2 border-t border-gray-200 pt-4 mt-6">
                <button type="submit" data-has-loading-state class="group btn--primary">
                    <span class="label">{{ "Save settings"|trans }}</span>
                    <span class="label--loading">{{ "Saving..."|trans }}</span>
                </button>
            </div>
        </form>
    </div>
{% endblock main %}
