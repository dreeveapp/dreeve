<div class="grid gap-2 sm:grid-cols-2">
    <div>
        <label class="mt-0! text-xs">{{ "Operator"|trans({}, 'admin') }}</label>
        <select name="{{ namePrefix }}[operator]" data-repeater-field="config.operator" class="mt-0">
            {% for operator in enum('App\\Domain\\Automation\\Condition\\ComparisonOperator').cases() %}
                <option value="{{ operator.value }}">{{ operator|trans }}</option>
            {% endfor %}
        </select>
    </div>
    <div>
        <label class="mt-0! text-xs">{{ "Distance (km)"|trans({}, 'admin') }}</label>
        <input type="number" step="0.1" min="0" name="{{ namePrefix }}[value]" data-repeater-field="config.value"
               required placeholder="10" class="mt-0">
    </div>
</div>
